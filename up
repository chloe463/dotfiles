function install_sheldon_plugins()
{
    if type sheldon > /dev/null 2>&1; then
        echo 'Installing sheldon plugins...'
        sheldon lock
    else
        echo 'ERROR: sheldon is not installed. Run: ./up brew' >&2
        return 1
    fi
}

# One-time migration of machine-local files into XDG locations.
# The `mkdir -p` runs every invocation (idempotent); the credentials move runs
# only when the legacy file exists and no regular file is already at the XDG
# destination, so re-running after a successful migration is a no-op.
function migrate_to_xdg()
{
    local xdg_config="${XDG_CONFIG_HOME:-$HOME/.config}"

    # Ensure ~/.config/zsh is a real directory before stow runs. Without this,
    # stow tree-folds the new package and links ~/.config/zsh straight to the
    # repo, causing machine-local files (e.g. credentials.zsh) to be written
    # inside the dotfiles checkout.
    mkdir -p "$xdg_config/zsh"

    # credentials: ~/.credentials.zsh -> $ZDOTDIR/credentials.zsh
    # Use `-f` (not `-e`) on the destination so a broken symlink there does not
    # mask the migration.
    if [ -f "$HOME/.credentials.zsh" ] && [ ! -f "$xdg_config/zsh/credentials.zsh" ]; then
        echo "Migrating ~/.credentials.zsh -> $xdg_config/zsh/credentials.zsh"
        mv "$HOME/.credentials.zsh" "$xdg_config/zsh/credentials.zsh" || {
            echo "ERROR: Failed to migrate ~/.credentials.zsh -> $xdg_config/zsh/credentials.zsh" >&2
            echo "       Your credentials file is still at ~/.credentials.zsh — no data was lost." >&2
            echo "       Check permissions on $xdg_config/zsh/ and retry." >&2
            return 1
        }
    fi
}

function run_stow()
{
    if type stow > /dev/null 2>&1; then
        echo "Making symlinks of dot files..."
        echo

        stow -R -vvv \
          alacritty \
          any-script-mcp \
          bat \
          gh \
          git \
          herdr \
          hunk \
          nvim \
          starship \
          zsh

        stow -R -vvv -t "$HOME/Library/Application Support/Code/User" vscode
        stow -R -vvv -t "$HOME/Library/Application Support/Cursor/User" cursor
        stow -R -vvv -t "$HOME/.claude" claude

        if [ ! -d $HOME/scripts ]; then
            mkdir $HOME/scripts
        fi
        stow -R -vvv -t "$HOME/scripts" scripts

        mkdir -p "$HOME/.local/bin"
        if ! stow -R -vvv bin; then
            echo "ERROR: 'stow -R bin' failed." >&2
            echo "       Check for conflicting files in ~/.local/bin/ and remove them." >&2
            return 1
        fi

        echo
        echo "🎉 Done!"
        echo
    else
        echo "ERROR: stow is not installed. Run: ./up brew" >&2
        return 1
    fi
}

function install_homebrew()
{
  # Install Homebrew
  if type brew > /dev/null 2>&1; then
    echo 'Homebrew has already been installed.'
  else
    echo 'Install Homebrew'
    # https://brew.sh
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    brew update
  fi

  echo "brew bundle --file=Brewfile.shared"
  if brew bundle --file=Brewfile.shared; then
    echo "Done. Run 'brew bundle --file=Brewfile.private' or 'brew bundle --file=Brewfile.work' to install more dependencies."
  else
    echo "ERROR: 'brew bundle --file=Brewfile.shared' failed." >&2
    return 1
  fi

  install_vscode_extensions
}

# Install VS Code extensions one at a time instead of via `brew bundle`'s
# vscode entries, which install concurrently and race on ~/.vscode/extensions/
# (see https://github.com/chloe463/dotfiles/issues/172).
function install_vscode_extensions()
{
  if ! type code > /dev/null 2>&1; then
    echo "ERROR: 'code' command not found. Run: ./up brew" >&2
    return 1
  fi

  echo 'Installing VS Code extensions...'
  while IFS= read -r extension; do
    [ -z "$extension" ] && continue
    echo "Installing extension: $extension"
    code --install-extension "$extension" --force || {
      echo "WARNING: Failed to install extension: $extension" >&2
    }
  done < "$BASE_DIR/vscode-extensions.txt"
}

function install_global_npm_packages()
{
  if type yarn > /dev/null 2>&1; then
    # yarn global list
    yarn global add \
        create-next-app \
        git-delete-squashed \
        git-split-diffs \
        npkill \
        # prettierd \
        yarn-deduplicate
  else
    echo 'Install yarn first!'
  fi
}

function main()
{
    case $1 in
        "sheldon")
            install_sheldon_plugins
            ;;
        "dot" | "dots" | "stow")
            migrate_to_xdg
            run_stow
            ;;
        "brew")
            install_homebrew
            ;;
        "npm" | "yarn")
            install_global_npm_packages
            ;;
        *)
            install_homebrew
            install_sheldon_plugins
            migrate_to_xdg
            run_stow
            install_global_npm_packages
            ;;
    esac
}

main ${1:-""}

